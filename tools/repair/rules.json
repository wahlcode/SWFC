  "FileSizeGuidelines": {
    "DomainMaxLines": 300,
    "ApplicationMaxLines": 250,
    "RazorMaxLines": 400
  },

  "SuspiciousPatterns": {
    "InlineStyleRegex": "style\\s*=\\s*\"",
    "DomainInWebRegex": "(Inventory|Maintenance|Energy|AccessRule|VisibilityResolver|AuditEntry)",
    "ConsumptionWordsRegex": "(Consumption|Verbrauch)",
    "MeasurementWordsRegex": "(Reading|Measurement|Meter)",
    "SecurityMixRegex": "(Auth|Authorization|Permission|Role|Visibility|Audit)",
    "DangerousDeleteRegex": "\\bDelete\\s*\\(",
    "UtcNowRecommendedRegex": "DateTime\\.UtcNow|DateTimeOffset\\.UtcNow"
  }
