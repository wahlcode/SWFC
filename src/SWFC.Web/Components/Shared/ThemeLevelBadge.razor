<span class="@BuildClass()">
    @BuildLabel()
</span>

@code {
    [Parameter]
    public string? Level { get; set; }

    private string BuildClass()
    {
        var baseClass = "theme-level";
        var normalized = Normalize(Level);

        var modifier = normalized switch
        {
            "core" => "theme-level--core",
            "optionalcore" => "theme-level--optional",
            "optional" => "theme-level--optional",
            "extension" => "theme-level--extension",
            _ => string.Empty
        };

        return string.IsNullOrWhiteSpace(modifier)
            ? baseClass
            : $"{baseClass} {modifier}";
    }

    private string BuildLabel()
    {
        var normalized = Normalize(Level);

        return normalized switch
        {
            "" => "Unbekannt",
            "optionalcore" => "Optionaler Kern",
            "optional" => "Optionaler Kern",
            "extension" => "Erweiterung",
            _ => "Kern"
        };
    }

    private static string Normalize(string? value)
        => (value ?? string.Empty).Trim().ToLowerInvariant();
}
