<span class="@CssClass">@Label</span>

@code {
    [Parameter] public string Level { get; set; } = "Core";

    private string CssClass => Level switch
    {
        "OptionalCore" => "theme-level theme-level--optional",
        "Extension" => "theme-level theme-level--extension",
        _ => "theme-level theme-level--core"
    };

    private string Label => Level switch
    {
        "OptionalCore" => "Optional Core",
        "Extension" => "Extension",
        _ => "Core"
    };
}