@page "/presentation/personalization"
@attribute [Authorize]

@using SWFC.Application.M800_Security.M802_ApplicationSecurity
@using SWFC.Web.Pages.M100_System.M106_Theme.Models
@using SWFC.Web.Pages.M100_System.M106_Theme.Services
@using SWFC.Web.Pages.M300_Presentation.M305_Forms.Components
@using SWFC.Web.Pages.M300_Presentation.M305_Forms.Models
@using SWFC.Web.Pages.M300_Presentation.M306_Localization.Services
@using SWFC.Web.Pages.M300_Presentation.M307_User_Personalization.Models
@using SWFC.Web.Pages.M300_Presentation.M307_User_Personalization.Services

@inject ICurrentUserService CurrentUserService
@inject LocalizationTextProvider TextProvider
@inject ThemeCatalogService ThemeCatalog
@inject UserUiPreferenceService PreferenceService

<PageTitle>@_pageTitle</PageTitle>

<div class="m307-personalization">
    <SwfcFormShell Eyebrow="M307"
                   Title="@_pageTitle"
                   Subtitle="@_subtitle"
                   Mode="FormMode.Edit"
                   ModeLabel="@_editText">
        <form method="post" action="/presentation/preferences/save" class="m307-personalization__form">
            <AntiforgeryToken />
            <input type="hidden" name="ReturnUrl" value="/presentation/personalization" />

            <SwfcFieldBlock FieldId="m307-theme"
                            LabelText="@_themeText"
                            Required="true"
                            HintText="@_themeHintText">
                <select id="m307-theme" name="ThemeName" required>
                    @foreach (var theme in _themeOptions)
                    {
                        <option value="@theme.Name" selected="@IsThemeSelected(theme.Name)">
                            @GetThemeLabel(theme)
                        </option>
                    }
                </select>
            </SwfcFieldBlock>

            <SwfcFieldBlock FieldId="m307-start-page"
                            LabelText="@_startPageText"
                            Required="true"
                            HintText="@_startPageHintText">
                <select id="m307-start-page" name="StartPageRoute" required>
                    @foreach (var startPage in UserUiPreferences.AllowedStartPageRoutes)
                    {
                        <option value="@startPage" selected="@IsStartPageSelected(startPage)">
                            @GetStartPageLabel(startPage)
                        </option>
                    }
                </select>
            </SwfcFieldBlock>

            <SwfcFieldBlock FieldId="m307-density"
                            LabelText="@_densityText"
                            Required="true">
                <select id="m307-density" name="NavigationDensity" required>
                    <option value="@UserUiPreferences.ComfortableDensity" selected="@IsDensitySelected(UserUiPreferences.ComfortableDensity)">
                        @_comfortableText
                    </option>
                    <option value="@UserUiPreferences.CompactDensity" selected="@IsDensitySelected(UserUiPreferences.CompactDensity)">
                        @_compactText
                    </option>
                </select>
            </SwfcFieldBlock>

            <div class="m307-personalization__widgets">
                <div class="m307-personalization__widgets-title">@_widgetsText</div>

                @foreach (var widgetKey in UserUiPreferences.AllowedDashboardWidgetKeys)
                {
                    <label class="m307-personalization__widget">
                        <input type="checkbox"
                               name="DashboardWidgetKeys"
                               value="@widgetKey"
                               checked="@_preferences.HasDashboardWidget(widgetKey)" />
                        <span>@GetWidgetLabel(widgetKey)</span>
                    </label>
                }
            </div>

            <label class="m307-personalization__toggle">
                <input type="checkbox"
                       name="UseReducedMotion"
                       value="true"
                       checked="@_preferences.UseReducedMotion" />
                <span>@_reducedMotionText</span>
            </label>

            <div class="m307-personalization__actions">
                <button type="submit" class="m307-personalization__save">@_saveText</button>
            </div>
        </form>
    </SwfcFormShell>
</div>

@code {
    private string _cultureName = LocalizationTextProvider.DefaultCultureName;
    private UserUiPreferences _preferences = UserUiPreferences.Default;
    private IReadOnlyList<ThemeOption> _themeOptions = Array.Empty<ThemeOption>();
    private readonly Dictionary<string, string> _themeLabels = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string> _startPageLabels = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string> _widgetLabels = new(StringComparer.OrdinalIgnoreCase);

    private string _pageTitle = "M307 Personalization";
    private string _subtitle = "User UI preferences";
    private string _editText = "Edit";
    private string _themeText = "Theme";
    private string _themeHintText = "Applies to the AppShell";
    private string _startPageText = "Start page";
    private string _startPageHintText = "Used when opening the dashboard root";
    private string _densityText = "Navigation density";
    private string _comfortableText = "Comfortable";
    private string _compactText = "Compact";
    private string _widgetsText = "Dashboard widgets";
    private string _reducedMotionText = "Reduced motion";
    private string _saveText = "Save";

    protected override async Task OnInitializedAsync()
    {
        var securityContext = await CurrentUserService.GetSecurityContextAsync();
        _cultureName = string.IsNullOrWhiteSpace(securityContext.PreferredCultureName)
            ? LocalizationTextProvider.DefaultCultureName
            : securityContext.PreferredCultureName.Trim();

        _preferences = await PreferenceService.GetCurrentAsync();
        _themeOptions = ThemeCatalog.GetThemeOptions();

        await LocalizeAsync();
    }

    private async Task LocalizeAsync()
    {
        _pageTitle = await TextProvider.GetTextAsync("Preferences.Title", _cultureName);
        _subtitle = await TextProvider.GetTextAsync("Preferences.Subtitle", _cultureName);
        _editText = await TextProvider.GetTextAsync("Common.Edit", _cultureName);
        _themeText = await TextProvider.GetTextAsync("Preferences.Theme", _cultureName);
        _themeHintText = await TextProvider.GetTextAsync("Preferences.ThemeHint", _cultureName);
        _startPageText = await TextProvider.GetTextAsync("Preferences.StartPage", _cultureName);
        _startPageHintText = await TextProvider.GetTextAsync("Preferences.StartPageHint", _cultureName);
        _densityText = await TextProvider.GetTextAsync("Preferences.NavigationDensity", _cultureName);
        _comfortableText = await TextProvider.GetTextAsync("Preferences.Density.Comfortable", _cultureName);
        _compactText = await TextProvider.GetTextAsync("Preferences.Density.Compact", _cultureName);
        _widgetsText = await TextProvider.GetTextAsync("Preferences.DashboardWidgets", _cultureName);
        _reducedMotionText = await TextProvider.GetTextAsync("Preferences.ReducedMotion", _cultureName);
        _saveText = await TextProvider.GetTextAsync("Common.Save", _cultureName);

        foreach (var theme in _themeOptions)
        {
            _themeLabels[theme.Name] = await TextProvider.GetTextAsync(theme.DisplayNameKey, _cultureName);
        }

        foreach (var startPage in UserUiPreferences.AllowedStartPageRoutes)
        {
            _startPageLabels[startPage] = await TextProvider.GetTextAsync($"Preferences.StartPage.{NormalizeKey(startPage)}", _cultureName);
        }

        foreach (var widgetKey in UserUiPreferences.AllowedDashboardWidgetKeys)
        {
            _widgetLabels[widgetKey] = await TextProvider.GetTextAsync($"Preferences.Widget.{widgetKey}", _cultureName);
        }
    }

    private bool IsThemeSelected(string themeName)
    {
        return string.Equals(_preferences.ThemeName, themeName, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsStartPageSelected(string startPageRoute)
    {
        return string.Equals(_preferences.StartPageRoute, startPageRoute, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsDensitySelected(string density)
    {
        return string.Equals(_preferences.NavigationDensity, density, StringComparison.OrdinalIgnoreCase);
    }

    private string GetThemeLabel(ThemeOption theme)
    {
        return _themeLabels.TryGetValue(theme.Name, out var label)
            ? label
            : theme.Name;
    }

    private string GetStartPageLabel(string route)
    {
        return _startPageLabels.TryGetValue(route, out var label)
            ? label
            : route;
    }

    private string GetWidgetLabel(string widgetKey)
    {
        return _widgetLabels.TryGetValue(widgetKey, out var label)
            ? label
            : widgetKey;
    }

    private static string NormalizeKey(string route)
    {
        return route.Trim('/').Replace("/", ".", StringComparison.OrdinalIgnoreCase);
    }
}
