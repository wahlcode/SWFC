@page "/auth/change-password"
@rendermode InteractiveServer
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using SWFC.Application.M100_System.M103_Authentication.Commands
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Abstractions
@using SWFC.Web.Models.Auth

@inject IUseCaseHandler<ChangeOwnPasswordCommand, bool> ChangeOwnPasswordHandler

<PageTitle>Passwort ändern</PageTitle>

<div class="form-container">
    <div class="form-card">
        <h1>Passwort ändern</h1>

        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="ChangePassword" Antiforgery="true">
            <DataAnnotationsValidator />
            <ValidationSummary />

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @_errorMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_successMessage))
            {
                <div class="alert alert-success" role="alert">
                    @_successMessage
                </div>
            }

            <div class="mb-3">
                <label class="form-label" for="currentPassword">Aktuelles Passwort</label>
                <InputText id="currentPassword" class="form-control" type="password" @bind-Value="_model.CurrentPassword" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="newPassword">Neues Passwort</label>
                <InputText id="newPassword" class="form-control" type="password" @bind-Value="_model.NewPassword" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="confirmNewPassword">Neues Passwort bestätigen</label>
                <InputText id="confirmNewPassword" class="form-control" type="password" @bind-Value="_model.ConfirmNewPassword" />
            </div>

            <button class="btn btn-primary" type="submit" disabled="@_isSubmitting">
                Passwort ändern
            </button>
        </EditForm>
    </div>
</div>

@code {
    [SupplyParameterFromForm(FormName = "ChangePassword")]
    private ChangePasswordModel _model { get; set; } = new();

    private bool _isSubmitting;
    private string? _errorMessage;
    private string? _successMessage;

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var result = await ChangeOwnPasswordHandler.HandleAsync(
                new ChangeOwnPasswordCommand(_model.CurrentPassword, _model.NewPassword));

            if (result.IsFailure)
            {
                _errorMessage = result.Error.Message;
                return;
            }

            _successMessage = "Passwort wurde erfolgreich geändert.";
            _model.CurrentPassword = string.Empty;
            _model.NewPassword = string.Empty;
            _model.ConfirmNewPassword = string.Empty;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}