@page "/m100/roles"

@using SWFC.Application.M100_System.M102_Organization.Queries
@using SWFC.Application.M100_System.M102_Organization.DTOs
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution

@inject IExecutionPipeline<GetRolesQuery, IReadOnlyList<RoleListItem>> Pipeline

<PageTitle>Roles</PageTitle>

<section class="m305-page">
    <div class="m305-page__header">
        <h2 class="m305-page__title">Roles</h2>
        <p class="m305-page__description">Übersicht über Rollen im M102-Organisationsmodell.</p>
    </div>

    <div class="m201-form-actions">
        <a class="m201-button" href="/m100/roles/create">Role anlegen</a>
    </div>

    <div class="m305-card">
        <div class="m305-card__body">
            @if (_isLoading)
            {
                <p>Lade Daten...</p>
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="m201-alert m201-alert--error">@_error</div>
            }
            else if (_roles.Count == 0)
            {
                <p>Keine Rollen vorhanden.</p>
            }
            else
            {
                <div style="overflow-x:auto; width:100%;">
                    <table class="table" style="min-width:700px; width:max-content;">
                        <thead>
                            <tr>
                                <th style="white-space:nowrap;">Name</th>
                                <th style="white-space:nowrap;">Description</th>
                                <th style="white-space:nowrap;">Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in _roles)
                            {
                                <tr>
                                    <td style="white-space:nowrap;">@role.Name</td>
                                    <td style="white-space:nowrap;">@DisplayOrDash(role.Description)</td>
                                    <td style="white-space:nowrap;">
                                        <a href="@($"/m100/roles/{role.Id}")">Details</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private bool _isLoading = true;
    private string? _error;
    private IReadOnlyList<RoleListItem> _roles = Array.Empty<RoleListItem>();

    protected override async Task OnInitializedAsync()
    {
        var result = await Pipeline.ExecuteAsync(new GetRolesQuery());

        if (result.IsSuccess)
        {
            _roles = result.Value;
        }
        else
        {
            _error = result.Error?.Message;
        }

        _isLoading = false;
    }

    private static string DisplayOrDash(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }
}