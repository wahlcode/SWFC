@page "/auth/login"
@attribute [AllowAnonymous]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Options
@using SWFC.Infrastructure.M100_System.M103_Authentication.Configuration
@using SWFC.Infrastructure.M400_Integration.M406_IdentityIntegration.Configuration

@inject IOptions<AuthenticationOptions> AuthenticationOptionsAccessor
@inject IOptions<IdentityIntegrationOptions> IdentityIntegrationOptionsAccessor

<PageTitle>Anmelden</PageTitle>

<section class="auth-page">
    <div class="auth-page__card">
        <div class="auth-page__header">
            <h1 class="auth-page__title">Anmelden</h1>
            <p class="auth-page__description">
                @DescriptionText
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="auth-page__alert auth-page__alert--error" role="alert">
                @ErrorMessage
            </div>
        }

        @if (LockoutUntilUtc.HasValue)
        {
            <div class="auth-page__alert auth-page__alert--warning" role="alert">
                Konto ist bis @LockoutUntilUtc.Value.LocalDateTime gesperrt.
            </div>
        }

        @if (IsSsoMode)
        {
            <div class="auth-page__actions">
                <a class="auth-page__button auth-page__button-link" href="@OidcLoginUrl">
                    Mit @SsoDisplayName anmelden
                </a>
            </div>
        }

        @if (ShowLocalLogin)
        {
            @if (IsSsoMode)
            {
                <div class="auth-page__divider" aria-hidden="true">
                    <span class="auth-page__divider-label">oder</span>
                </div>

                <section class="auth-page__section">
                    <h2 class="auth-page__section-title">Lokaler Notfallzugang</h2>
                    <p class="auth-page__section-note">
                        Nur fuer den systemseitig freigegebenen geschuetzten SuperAdmin.
                    </p>
                </section>
            }

            <form method="post" action="/auth/login/submit">
                <AntiforgeryToken />

                @if (!string.IsNullOrWhiteSpace(ReturnUrl))
                {
                    <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
                }

                <div class="auth-page__field">
                    <label class="auth-page__label" for="username">Benutzername</label>
                    <input id="username"
                           name="Username"
                           class="auth-page__input"
                           minlength="3"
                           maxlength="100"
                           autocomplete="username"
                           required />
                </div>

                <div class="auth-page__field">
                    <label class="auth-page__label" for="password">Passwort</label>
                    <input id="password"
                           name="Password"
                           class="auth-page__input"
                           type="password"
                           autocomplete="current-password"
                           required />
                </div>

                <div class="auth-page__checkbox-row">
                    <input type="hidden" name="RememberMe" value="false" />
                    <input id="rememberMe"
                           name="RememberMe"
                           class="auth-page__checkbox"
                           type="checkbox"
                           value="true" />
                    <label class="auth-page__checkbox-label" for="rememberMe">
                        Angemeldet bleiben
                    </label>
                </div>

                <div class="auth-page__actions">
                    <button class="auth-page__button" type="submit">
                        Anmelden
                    </button>
                </div>
            </form>
        }
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorMessage { get; set; }

    [SupplyParameterFromQuery(Name = "lockoutUntilUtc")]
    public string? LockoutUntilUtcValue { get; set; }

    [SupplyParameterFromQuery(Name = "ReturnUrl")]
    public string? ReturnUrl { get; set; }

    private bool IsSsoMode =>
        string.Equals(
            AuthenticationOptionsAccessor.Value.Mode,
            AuthenticationModes.Sso,
            StringComparison.OrdinalIgnoreCase);

    private string SsoDisplayName =>
        string.IsNullOrWhiteSpace(IdentityIntegrationOptionsAccessor.Value.Oidc.DisplayName)
            ? "Single Sign-On"
            : IdentityIntegrationOptionsAccessor.Value.Oidc.DisplayName;

    private string DescriptionText =>
        IsSsoMode
            ? BreakGlassLoginEnabled
                ? $"Mit {SsoDisplayName} an SWFC anmelden. Ein lokaler Notfallzugang ist systemseitig freigegeben."
                : $"Mit {SsoDisplayName} an SWFC anmelden."
            : "Mit lokalem Benutzerkonto an SWFC anmelden.";

    private string OidcLoginUrl =>
        string.IsNullOrWhiteSpace(ReturnUrl)
            ? "/auth/oidc/login"
            : $"/auth/oidc/login?returnUrl={Uri.EscapeDataString(ReturnUrl)}";

    private bool BreakGlassLoginEnabled =>
        IsSsoMode &&
        !string.IsNullOrWhiteSpace(AuthenticationOptionsAccessor.Value.InitialSuperAdmin.Password);

    private bool ShowLocalLogin =>
        !IsSsoMode || BreakGlassLoginEnabled;

    private DateTimeOffset? LockoutUntilUtc =>
        DateTimeOffset.TryParse(LockoutUntilUtcValue, out var value)
            ? value
            : null;
}


