@page "/auth/change-password"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using SWFC.Application.M100_System.M103_Authentication
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Abstractions
@using SWFC.Web.Pages.M100_System.M103_Authentication.Models

@inject IUseCaseHandler<ChangeOwnPasswordCommand, bool> ChangePasswordHandler

<section class="auth-page">
    <div class="auth-page__card">

        <h1 class="auth-page__title">Passwort �ndern</h1>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="auth-page__alert auth-page__alert--error">
                @_error
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_success))
        {
            <div class="auth-page__alert auth-page__alert--success">
                @_success
            </div>
        }

        <EditForm Model="_model"
                  OnValidSubmit="Save"
                  FormName="ChangePasswordForm"
                  Antiforgery="true">
            <DataAnnotationsValidator />

            <div class="auth-page__field">
                <label class="auth-page__label" for="currentPassword">Aktuelles Passwort</label>
                <InputText id="currentPassword"
                           type="password"
                           class="auth-page__input"
                           @bind-Value="_model.CurrentPassword" />
            </div>

            <div class="auth-page__field">
                <label class="auth-page__label" for="newPassword">Neues Passwort</label>
                <InputText id="newPassword"
                           type="password"
                           class="auth-page__input"
                           @bind-Value="_model.NewPassword" />
            </div>

            <div class="auth-page__field">
                <label class="auth-page__label" for="confirmPassword">Best�tigen</label>
                <InputText id="confirmPassword"
                           type="password"
                           class="auth-page__input"
                           @bind-Value="_model.ConfirmPassword" />
            </div>

            <div class="auth-page__actions">
                <button class="auth-page__button" type="submit">
                    Speichern
                </button>
            </div>
        </EditForm>

    </div>
</section>

@code {
    private string? _error;
    private string? _success;

    private ChangePasswordModel _model = new();

    private async Task Save()
    {
        _error = null;
        _success = null;

        if (_model.NewPassword != _model.ConfirmPassword)
        {
            _error = "Passw�rter stimmen nicht �berein.";
            return;
        }

        var result = await ChangePasswordHandler.HandleAsync(
            new ChangeOwnPasswordCommand(
                _model.CurrentPassword,
                _model.NewPassword));

        if (result.IsFailure)
        {
            _error = result.Error.Message;
            return;
        }

        if (!result.Value)
        {
            _error = "Passwort konnte nicht ge�ndert werden.";
            return;
        }

        _success = "Passwort erfolgreich ge�ndert.";
        _model = new ChangePasswordModel();
    }
}


