@page "/m100/organization-units"

@using SWFC.Application.M100_System.M102_Organization.Queries
@using SWFC.Application.M100_System.M102_Organization.DTOs
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution

@inject IExecutionPipeline<GetOrganizationUnitsQuery, IReadOnlyList<OrganizationUnitListItem>> Pipeline

<PageTitle>Organization Units</PageTitle>

<section class="m305-page">
    <div class="m305-page__header">
        <h2 class="m305-page__title">Organization Units</h2>
        <p class="m305-page__description">Übersicht über die Organisationsstruktur.</p>
    </div>

    <div class="m201-form-actions">
        <a class="m201-button" href="/m100/organization-units/create">Organization Unit anlegen</a>
    </div>

    <div class="m305-card">
        <div class="m305-card__body">
            @if (_isLoading)
            {
                <p>Lade Daten...</p>
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="m201-alert m201-alert--error">@_error</div>
            }
            else if (_organizationUnits.Count == 0)
            {
                <p>Keine Organization Units vorhanden.</p>
            }
            else
            {
                <div style="overflow-x:auto; width:100%;">
                    <table class="table" style="min-width:900px; width:max-content;">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Code</th>
                                <th>Parent</th>
                                <th>Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _organizationUnits)
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td>@item.Code</td>
                                    <td>@DisplayParent(item)</td>
                                    <td>
                                        <a href="@($"/m100/organization-units/{item.Id}")">Details</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private bool _isLoading = true;
    private string? _error;
    private IReadOnlyList<OrganizationUnitListItem> _organizationUnits = Array.Empty<OrganizationUnitListItem>();

    protected override async Task OnInitializedAsync()
    {
        var result = await Pipeline.ExecuteAsync(new GetOrganizationUnitsQuery());

        if (result.IsSuccess)
        {
            _organizationUnits = result.Value;
        }
        else
        {
            _error = result.Error?.Message;
        }

        _isLoading = false;
    }

    private static string DisplayParent(OrganizationUnitListItem item)
    {
        if (!string.IsNullOrWhiteSpace(item.ParentName) && !string.IsNullOrWhiteSpace(item.ParentCode))
        {
            return $"{item.ParentName} ({item.ParentCode})";
        }

        if (!string.IsNullOrWhiteSpace(item.ParentName))
        {
            return item.ParentName;
        }

        if (!string.IsNullOrWhiteSpace(item.ParentCode))
        {
            return item.ParentCode;
        }

        return "-";
    }
}