@page "/m100/organization-units/{Id:guid}"

@using SWFC.Application.M100_System.M102_Organization.Queries
@using SWFC.Application.M100_System.M102_Organization.DTOs
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution

@inject IExecutionPipeline<GetOrganizationUnitByIdQuery, OrganizationUnitDetailsDto> Pipeline

<PageTitle>Organization Unit Detail</PageTitle>

<section class="m305-page">
    <div class="m305-page__header">
        <h2 class="m305-page__title">Organization Unit Detail</h2>
        <p class="m305-page__description">Detailansicht einer Organisationseinheit.</p>
    </div>

    <div class="m305-card">
        <div class="m305-card__body">
            @if (_isLoading)
            {
                <p>Lade Daten...</p>
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="m201-alert m201-alert--error">@_error</div>
            }
            else if (_organizationUnit is not null)
            {
                <dl>
                    <dt>Id</dt>
                    <dd>@_organizationUnit.Id</dd>

                    <dt>Name</dt>
                    <dd>@_organizationUnit.Name</dd>

                    <dt>Code</dt>
                    <dd>@_organizationUnit.Code</dd>

                    <dt>Parent</dt>
                    <dd>@DisplayParent(_organizationUnit)</dd>
                </dl>

                <div class="m201-form-actions">
                    <a class="m201-button m201-button--secondary" href="/m100/organization-units">Zur Liste</a>
                </div>
            }
        </div>
    </div>
</section>

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _isLoading = true;
    private string? _error;
    private OrganizationUnitDetailsDto? _organizationUnit;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _error = null;

        var result = await Pipeline.ExecuteAsync(new GetOrganizationUnitByIdQuery(Id));

        if (result.IsSuccess)
        {
            _organizationUnit = result.Value;
        }
        else
        {
            _error = result.Error?.Message;
        }

        _isLoading = false;
    }

    private static string DisplayParent(OrganizationUnitDetailsDto item)
    {
        if (!string.IsNullOrWhiteSpace(item.ParentName) && !string.IsNullOrWhiteSpace(item.ParentCode))
        {
            return $"{item.ParentName} ({item.ParentCode})";
        }

        if (!string.IsNullOrWhiteSpace(item.ParentName))
        {
            return item.ParentName;
        }

        if (!string.IsNullOrWhiteSpace(item.ParentCode))
        {
            return item.ParentCode;
        }

        return "-";
    }
}