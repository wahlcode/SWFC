@page "/system/organization-units/{Id:guid?}"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@attribute [Authorize]

@using SWFC.Application.M100_System.M102_Organization.OrganizationUnits
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution
@using SWFC.Web.Pages.M300_Presentation.M306_Localization.Services

@inject IExecutionPipeline<GetOrganizationUnitByIdQuery, OrganizationUnitDetailsDto> GetOrganizationUnitPipeline
@inject IExecutionPipeline<GetOrganizationUnitsQuery, IReadOnlyList<OrganizationUnitListItem>> GetOrganizationUnitsPipeline
@inject IExecutionPipeline<CreateOrganizationUnitCommand, Guid> CreateOrganizationUnitPipeline
@inject IExecutionPipeline<UpdateOrganizationUnitCommand, bool> UpdateOrganizationUnitPipeline
@inject NavigationManager NavigationManager
@inject LocalizationTextProvider TextProvider

<section class="m100-ou-detail">

    <header class="m100-ou-detail__header">
        <div class="m100-ou-detail__title">
            <a href="/system/organization-units" class="m100-ou-detail__back">@_backText</a>
            <p class="m100-ou-detail__eyebrow">@_eyebrowText</p>
            <h1>@(IsNew ? _newTitleText : _editTitleText)</h1>
            <p>@_subtitleText</p>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="m100-alert m100-alert--error">@_error</div>
    }

    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <div class="m100-alert m100-alert--success">@_success</div>
    }

    @if (_isLoading)
    {
        <div class="m100-loading">@_loadingText</div>
    }
    else
    {
        <div class="m100-ou-detail__layout">

            <div class="m100-card m100-ou-detail__form">
                <label class="m100-ou-detail__field">
                    <span>@_nameText</span>
                    <input class="m100-input"
                           aria-label="@_nameText"
                           @bind="_model.Name" />
                </label>

                <label class="m100-ou-detail__field">
                    <span>@_codeText</span>
                    <input class="m100-input"
                           aria-label="@_codeText"
                           @bind="_model.Code" />
                </label>

                <label class="m100-ou-detail__field">
                    <span>@_parentUnitText</span>
                    <select class="m100-input"
                            aria-label="@_parentUnitText"
                            @bind="_model.ParentId">
                        <option value="">@_noParentText</option>
                        @foreach (var unit in _parentOptions)
                        {
                            <option value="@unit.Id">@unit.Name (@unit.Code)</option>
                        }
                    </select>
                </label>

                @if (!IsNew)
                {
                    <label class="m100-ou-detail__checkbox">
                        <input type="checkbox" @bind="_model.IsActive" />
                        <span>@_activeText</span>
                    </label>
                }

                <label class="m100-ou-detail__field">
                    <span>@_reasonText</span>
                    <textarea class="m100-textarea"
                              aria-label="@_reasonText"
                              @bind="_model.Reason"></textarea>
                </label>

                <div class="m100-actions">
                    <button class="m100-button"
                            @onclick="SaveAsync"
                            disabled="@_isBusy">
                        @_saveText
                    </button>

                    <a href="/system/organization-units" class="m100-button m100-button--secondary">
                        @_backToListText
                    </a>
                </div>
            </div>

            <div class="m100-card m100-ou-detail__side">
                @if (IsNew)
                {
                    <div class="m100-muted">@_newInfoText</div>
                }
                else if (_organizationUnit is not null)
                {
                    <section class="m100-ou-detail__section">
                        <h3>@_currentStateText</h3>
                        <dl class="m100-ou-detail__summary">
                            <div>
                                <dt>@_nameText</dt>
                                <dd>@_organizationUnit.Name</dd>
                            </div>
                            <div>
                                <dt>@_codeText</dt>
                                <dd>@_organizationUnit.Code</dd>
                            </div>
                            <div>
                                <dt>@_parentText</dt>
                                <dd>@BuildParentLabel(_organizationUnit)</dd>
                            </div>
                            <div>
                                <dt>@_statusText</dt>
                                <dd>@(_organizationUnit.IsActive ? _activeText : _inactiveText)</dd>
                            </div>
                        </dl>
                    </section>

                    <section class="m100-ou-detail__section">
                        <h3>@_directChildUnitsText</h3>

                        @if (ChildUnits.Count == 0)
                        {
                            <p class="m100-muted">@_noDirectChildUnitsText</p>
                        }
                        else
                        {
                            <div class="m100-ou-detail__children">
                                @foreach (var child in ChildUnits)
                                {
                                    <div class="m100-ou-detail__child">
                                        <div class="m100-ou-detail__child-title">@child.Name</div>
                                        <div class="m100-ou-detail__child-meta">@child.Code</div>
                                    </div>
                                }
                            </div>
                        }
                    </section>
                }
            </div>

        </div>
    }

</section>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool _isLoading = true;
    private bool _isBusy;
    private string? _error;
    private string? _success;

    private OrganizationUnitDetailsDto? _organizationUnit;
    private IReadOnlyList<OrganizationUnitListItem> _allUnits = [];
    private List<OrganizationUnitListItem> _parentOptions = [];
    private OrganizationUnitInputModel _model = new();

    private string _backText = "Back";
    private string _eyebrowText = "M102 · Organization";
    private string _newTitleText = "New organization unit";
    private string _editTitleText = "Edit organization unit";
    private string _subtitleText = "Master data and parent references are maintained only through existing M102 fields.";
    private string _loadingText = "Loading data...";
    private string _nameText = "Name";
    private string _codeText = "Code";
    private string _parentText = "Parent";
    private string _parentUnitText = "Parent unit";
    private string _noParentText = "-- no parent --";
    private string _activeText = "Active";
    private string _inactiveText = "Inactive";
    private string _reasonText = "Reason";
    private string _saveText = "Save";
    private string _backToListText = "Back to list";
    private string _newInfoText = "New organization unit. After saving, the structure can be checked in detail.";
    private string _currentStateText = "Current state";
    private string _statusText = "Status";
    private string _directChildUnitsText = "Direct child units";
    private string _noDirectChildUnitsText = "No direct child units available.";
    private string _loadFailedText = "Organization units could not be loaded.";
    private string _itemLoadFailedText = "Could not be loaded.";
    private string _createdText = "Organization unit created.";
    private string _updatedText = "Updated.";

    private bool IsNew => !Id.HasValue;

    private IReadOnlyList<OrganizationUnitListItem> ChildUnits =>
        !Id.HasValue
            ? []
            : _allUnits
                .Where(x => x.ParentId == Id.Value)
                .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
                .ThenBy(x => x.Code, StringComparer.OrdinalIgnoreCase)
                .ToList();

    protected override async Task OnParametersSetAsync()
    {
        await LoadTextsAsync();
        await LoadAsync();
    }

    private async Task LoadTextsAsync()
    {
        var culture = LocalizationTextProvider.DefaultCultureName;

        _backText = await TextProvider.GetTextAsync("Common.Back", culture);
        _eyebrowText = await TextProvider.GetTextAsync("OrganizationUnitDetail.Eyebrow", culture);
        _newTitleText = await TextProvider.GetTextAsync("OrganizationUnitDetail.NewTitle", culture);
        _editTitleText = await TextProvider.GetTextAsync("OrganizationUnitDetail.EditTitle", culture);
        _subtitleText = await TextProvider.GetTextAsync("OrganizationUnitDetail.Subtitle", culture);
        _loadingText = await TextProvider.GetTextAsync("OrganizationUnitDetail.Loading", culture);
        _nameText = await TextProvider.GetTextAsync("Common.Name", culture);
        _codeText = await TextProvider.GetTextAsync("Common.Code", culture);
        _parentText = await TextProvider.GetTextAsync("Common.Parent", culture);
        _parentUnitText = await TextProvider.GetTextAsync("OrganizationUnitDetail.ParentUnit", culture);
        _noParentText = await TextProvider.GetTextAsync("Common.NoParent", culture);
        _activeText = await TextProvider.GetTextAsync("Common.Active", culture);
        _inactiveText = await TextProvider.GetTextAsync("Common.Inactive", culture);
        _reasonText = await TextProvider.GetTextAsync("Common.Reason", culture);
        _saveText = await TextProvider.GetTextAsync("Common.Save", culture);
        _backToListText = await TextProvider.GetTextAsync("OrganizationUnitDetail.BackToList", culture);
        _newInfoText = await TextProvider.GetTextAsync("OrganizationUnitDetail.NewInfo", culture);
        _currentStateText = await TextProvider.GetTextAsync("OrganizationUnitDetail.CurrentState", culture);
        _statusText = await TextProvider.GetTextAsync("UserDetail.Status", culture);
        _directChildUnitsText = await TextProvider.GetTextAsync("OrganizationUnitDetail.DirectChildUnits", culture);
        _noDirectChildUnitsText = await TextProvider.GetTextAsync("OrganizationUnitDetail.NoDirectChildUnits", culture);
        _loadFailedText = await TextProvider.GetTextAsync("OrganizationUnitDetail.LoadFailed", culture);
        _itemLoadFailedText = await TextProvider.GetTextAsync("OrganizationUnitDetail.ItemLoadFailed", culture);
        _createdText = await TextProvider.GetTextAsync("OrganizationUnitDetail.Created", culture);
        _updatedText = await TextProvider.GetTextAsync("OrganizationUnitDetail.Updated", culture);
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        _success = null;

        try
        {
            var unitsResult = await GetOrganizationUnitsPipeline.ExecuteAsync(new GetOrganizationUnitsQuery());

            if (unitsResult.IsSuccess && unitsResult.Value is not null)
            {
                _allUnits = unitsResult.Value;

                _parentOptions = _allUnits
                    .Where(x => x.IsActive)
                    .Where(x => !Id.HasValue || x.Id != Id.Value)
                    .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
                    .ThenBy(x => x.Code, StringComparer.OrdinalIgnoreCase)
                    .ToList();
            }
            else if (!unitsResult.IsSuccess)
            {
                _error = unitsResult.Error?.Message ?? _loadFailedText;
            }

            if (IsNew)
            {
                _organizationUnit = null;
                _model = new OrganizationUnitInputModel();
                return;
            }

            var result = await GetOrganizationUnitPipeline.ExecuteAsync(new GetOrganizationUnitByIdQuery(Id!.Value));

            if (result.IsSuccess && result.Value is not null)
            {
                _organizationUnit = result.Value;

                _model = new OrganizationUnitInputModel
                {
                    Name = result.Value.Name,
                    Code = result.Value.Code,
                    ParentId = result.Value.ParentId,
                    IsActive = result.Value.IsActive,
                    Reason = string.Empty
                };
            }
            else
            {
                _error = result.Error?.Message ?? _itemLoadFailedText;
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        _error = null;
        _success = null;
        _isBusy = true;

        try
        {
            if (IsNew)
            {
                var createResult = await CreateOrganizationUnitPipeline.ExecuteAsync(
                    new CreateOrganizationUnitCommand(
                        _model.Name,
                        _model.Code,
                        _model.ParentId,
                        _model.Reason));

                if (!createResult.IsSuccess)
                {
                    _error = createResult.Error?.Message;
                    return;
                }

                _success = _createdText;
                NavigationManager.NavigateTo($"/system/organization-units/{createResult.Value}");
                return;
            }

            var updateResult = await UpdateOrganizationUnitPipeline.ExecuteAsync(
                new UpdateOrganizationUnitCommand(
                    Id!.Value,
                    _model.Name,
                    _model.Code,
                    _model.ParentId,
                    _model.IsActive,
                    _model.Reason));

            if (!updateResult.IsSuccess)
            {
                _error = updateResult.Error?.Message;
                return;
            }

            _success = _updatedText;
            await LoadAsync();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private static string BuildParentLabel(OrganizationUnitDetailsDto item)
    {
        if (!string.IsNullOrWhiteSpace(item.ParentName) && !string.IsNullOrWhiteSpace(item.ParentCode))
        {
            return $"{item.ParentName} ({item.ParentCode})";
        }

        return item.ParentName ?? item.ParentCode ?? "-";
    }

    private sealed class OrganizationUnitInputModel
    {
        public string Name { get; set; } = string.Empty;
        public string Code { get; set; } = string.Empty;
        public Guid? ParentId { get; set; }
        public bool IsActive { get; set; } = true;
        public string Reason { get; set; } = string.Empty;
    }
}