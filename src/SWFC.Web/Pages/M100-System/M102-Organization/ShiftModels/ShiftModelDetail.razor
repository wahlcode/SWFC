@page "/system/shift-models/{Id:guid?}"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@attribute [Authorize]

@using SWFC.Application.M100_System.M102_Organization.ShiftModels
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution
@using SWFC.Web.Pages.M300_Presentation.M306_Localization.Services

@inject IExecutionPipeline<GetShiftModelByIdQuery, ShiftModelDetailsDto> GetShiftModelPipeline
@inject IExecutionPipeline<CreateShiftModelCommand, Guid> CreateShiftModelPipeline
@inject IExecutionPipeline<UpdateShiftModelCommand, bool> UpdateShiftModelPipeline
@inject NavigationManager NavigationManager
@inject LocalizationTextProvider TextProvider

<section class="m100-ou-detail">

    <div class="m100-ou-detail__header">
        <h1>@(IsNew ? _newTitleText : _editTitleText)</h1>

        <a href="/system/shift-models" class="m100-link">
            @_backText
        </a>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="m100-alert m100-alert--error">@_error</div>
    }

    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <div class="m100-alert m100-alert--success">@_success</div>
    }

    @if (_isLoading)
    {
        <div class="m100-loading">@_loadingText</div>
    }
    else
    {
        <div class="m100-ou-detail__layout">

            <div class="m100-card">

                <input class="m100-input"
                       aria-label="@_nameText"
                       @bind="_model.Name" />

                <input class="m100-input"
                       aria-label="@_codeText"
                       @bind="_model.Code" />

                <textarea class="m100-textarea"
                          aria-label="@_descriptionText"
                          @bind="_model.Description"></textarea>

                <label class="m100-checkbox">
                    <input type="checkbox" @bind="_model.IsActive" />
                    @_activeText
                </label>

                <textarea class="m100-textarea"
                          aria-label="@_reasonText"
                          @bind="_model.Reason"></textarea>

                <button class="m100-button"
                        @onclick="SaveAsync"
                        disabled="@_isBusy">
                    @_saveText
                </button>

            </div>

            <div class="m100-card m100-ou-detail__side">

                @if (IsNew)
                {
                    <div class="m100-muted">@_newTitleText</div>
                }
                else if (_shiftModel is not null)
                {
                    <ul class="m100-list">
                        <li><strong>@_nameText:</strong> @_shiftModel.Name</li>
                        <li><strong>@_codeText:</strong> @_shiftModel.Code</li>
                        <li><strong>@_descriptionText:</strong> @(string.IsNullOrWhiteSpace(_shiftModel.Description) ? "-" : _shiftModel.Description)</li>
                        <li><strong>@_activeText:</strong> @(_shiftModel.IsActive ? _yesText : _noText)</li>
                    </ul>
                }

            </div>

        </div>
    }

</section>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool _isLoading = true;
    private bool _isBusy;
    private string? _error;
    private string? _success;

    private ShiftModelDetailsDto? _shiftModel;
    private ShiftModelInputModel _model = new();

    private string _newTitleText = "New shift model";
    private string _editTitleText = "Edit shift model";
    private string _backText = "Back";
    private string _loadingText = "Loading data...";
    private string _nameText = "Name";
    private string _codeText = "Code";
    private string _descriptionText = "Description";
    private string _activeText = "Active";
    private string _reasonText = "Reason";
    private string _saveText = "Save";
    private string _yesText = "Yes";
    private string _noText = "No";
    private string _itemLoadFailedText = "Could not be loaded.";
    private string _createdText = "Created";
    private string _updatedText = "Updated";

    private bool IsNew => !Id.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        await LoadTextsAsync();
        await LoadAsync();
    }

    private async Task LoadTextsAsync()
    {
        var culture = LocalizationTextProvider.DefaultCultureName;

        _newTitleText = await TextProvider.GetTextAsync("ShiftModelDetail.NewTitle", culture);
        _editTitleText = await TextProvider.GetTextAsync("ShiftModelDetail.EditTitle", culture);
        _backText = await TextProvider.GetTextAsync("Common.Back", culture);
        _loadingText = await TextProvider.GetTextAsync("ShiftModelDetail.Loading", culture);
        _nameText = await TextProvider.GetTextAsync("Common.Name", culture);
        _codeText = await TextProvider.GetTextAsync("Common.Code", culture);
        _descriptionText = await TextProvider.GetTextAsync("Common.Description", culture);
        _activeText = await TextProvider.GetTextAsync("Common.Active", culture);
        _reasonText = await TextProvider.GetTextAsync("Common.Reason", culture);
        _saveText = await TextProvider.GetTextAsync("Common.Save", culture);
        _yesText = await TextProvider.GetTextAsync("Common.Yes", culture);
        _noText = await TextProvider.GetTextAsync("Common.No", culture);
        _itemLoadFailedText = await TextProvider.GetTextAsync("ShiftModelDetail.ItemLoadFailed", culture);
        _createdText = await TextProvider.GetTextAsync("ShiftModelDetail.Created", culture);
        _updatedText = await TextProvider.GetTextAsync("ShiftModelDetail.Updated", culture);
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        _success = null;

        if (IsNew)
        {
            _shiftModel = null;
            _model = new ShiftModelInputModel();
            _isLoading = false;
            return;
        }

        var result = await GetShiftModelPipeline.ExecuteAsync(new GetShiftModelByIdQuery(Id!.Value));

        if (result.IsSuccess && result.Value is not null)
        {
            _shiftModel = result.Value;
            _model = new ShiftModelInputModel
            {
                Name = result.Value.Name,
                Code = result.Value.Code,
                Description = result.Value.Description,
                IsActive = result.Value.IsActive,
                Reason = string.Empty
            };
        }
        else
        {
            _error = result.Error?.Message ?? _itemLoadFailedText;
        }

        _isLoading = false;
    }

    private async Task SaveAsync()
    {
        _error = null;
        _success = null;
        _isBusy = true;

        try
        {
            if (IsNew)
            {
                var createResult = await CreateShiftModelPipeline.ExecuteAsync(
                    new CreateShiftModelCommand(
                        _model.Name,
                        _model.Code,
                        _model.Description,
                        _model.Reason));

                if (!createResult.IsSuccess)
                {
                    _error = createResult.Error?.Message;
                    return;
                }

                _success = _createdText;
                NavigationManager.NavigateTo($"/system/shift-models/{createResult.Value}");
                return;
            }

            var updateResult = await UpdateShiftModelPipeline.ExecuteAsync(
                new UpdateShiftModelCommand(
                    Id!.Value,
                    _model.Name,
                    _model.Code,
                    _model.Description,
                    _model.IsActive,
                    _model.Reason));

            if (!updateResult.IsSuccess)
            {
                _error = updateResult.Error?.Message;
                return;
            }

            _success = _updatedText;
            await LoadAsync();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private sealed class ShiftModelInputModel
    {
        public string Name { get; set; } = string.Empty;
        public string Code { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool IsActive { get; set; } = true;
        public string Reason { get; set; } = string.Empty;
    }
}