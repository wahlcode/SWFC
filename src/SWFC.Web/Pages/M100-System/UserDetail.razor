@page "/m100/users/{Id:guid}"

@using SWFC.Application.M100_System.M102_Organization.Queries
@using SWFC.Application.M100_System.M102_Organization.DTOs
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution

@inject IExecutionPipeline<GetUserByIdQuery, UserDetailsDto> Pipeline

<PageTitle>User Detail</PageTitle>

<section class="m305-page">
    <div class="m305-page__header">
        <h2 class="m305-page__title">User Detail</h2>
        <p class="m305-page__description">Detailansicht eines Benutzers inklusive Rollen und Organization Units.</p>
    </div>

    <div class="m305-card">
        <div class="m305-card__body">
            @if (_isLoading)
            {
                <p>Lade Daten...</p>
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="m201-alert m201-alert--error">@_error</div>
            }
            else if (_user is not null)
            {
                <dl>
                    <dt>Id</dt>
                    <dd>@_user.Id</dd>

                    <dt>Identity Key</dt>
                    <dd>@_user.IdentityKey</dd>

                    <dt>Username</dt>
                    <dd>@_user.Username</dd>

                    <dt>Display Name</dt>
                    <dd>@_user.DisplayName</dd>

                    <dt>Active</dt>
                    <dd>@(_user.IsActive ? "Ja" : "Nein")</dd>

                    <dt>Roles</dt>
                    <dd>
                        @if (_user.Roles.Count == 0)
                        {
                            <span>-</span>
                        }
                        else
                        {
                            @foreach (var role in _user.Roles)
                            {
                                <div>@role</div>
                            }
                        }
                    </dd>

                    <dt>Organization Units</dt>
                    <dd>
                        @if (_user.OrganizationUnits.Count == 0)
                        {
                            <span>-</span>
                        }
                        else
                        {
                            @foreach (var organizationUnit in _user.OrganizationUnits)
                            {
                                <div>@organizationUnit.Name (@organizationUnit.Code)</div>
                            }
                        }
                    </dd>
                </dl>

                <div class="m201-form-actions">
                    <a class="m201-button" href="@($"/m100/users/{_user.Id}/edit")">Bearbeiten</a>
                    <a class="m201-button m201-button--secondary" href="/m100/users">Zur Liste</a>
                </div>
            }
        </div>
    </div>
</section>

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _isLoading = true;
    private string? _error;
    private UserDetailsDto? _user;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _error = null;

        var result = await Pipeline.ExecuteAsync(new GetUserByIdQuery(Id));

        if (result.IsSuccess)
        {
            _user = result.Value;
        }
        else
        {
            _error = result.Error?.Message;
        }

        _isLoading = false;
    }
}