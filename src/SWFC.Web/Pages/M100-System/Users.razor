@page "/m100/users"

@using SWFC.Application.M100_System.M102_Organization.Queries
@using SWFC.Application.M100_System.M102_Organization.DTOs
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution

@inject IExecutionPipeline<GetUsersQuery, IReadOnlyList<UserListItem>> Pipeline

<PageTitle>Users</PageTitle>

<section class="m305-page">
    <div class="m305-page__header">
        <h2 class="m305-page__title">Users</h2>
        <p class="m305-page__description">Übersicht über Benutzer im M102-Organisationsmodell.</p>
    </div>

    <div class="m201-form-actions">
        <a class="m201-button" href="/m100/users/create">User anlegen</a>
    </div>

    <div class="m305-card">
        <div class="m305-card__body">
            @if (_isLoading)
            {
                <p>Lade Daten...</p>
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="m201-alert m201-alert--error">@_error</div>
            }
            else if (_users.Count == 0)
            {
                <p>Keine User vorhanden.</p>
            }
            else
            {
                <div style="overflow-x:auto; width:100%;">
                    <table class="table" style="min-width:980px; width:max-content;">
                        <thead>
                            <tr>
                                <th style="white-space:nowrap;">Identity Key</th>
                                <th style="white-space:nowrap;">Username</th>
                                <th style="white-space:nowrap;">Display Name</th>
                                <th style="white-space:nowrap;">Active</th>
                                <th style="white-space:nowrap;">Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in _users)
                            {
                                <tr>
                                    <td style="white-space:nowrap;">@user.IdentityKey</td>
                                    <td style="white-space:nowrap;">@user.Username</td>
                                    <td style="white-space:nowrap;">@user.DisplayName</td>
                                    <td style="white-space:nowrap;">@(user.IsActive ? "Ja" : "Nein")</td>
                                    <td style="white-space:nowrap;">
                                        <a href="@($"/m100/users/{user.Id}")">Details</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private bool _isLoading = true;
    private string? _error;
    private IReadOnlyList<UserListItem> _users = Array.Empty<UserListItem>();

    protected override async Task OnInitializedAsync()
    {
        var result = await Pipeline.ExecuteAsync(new GetUsersQuery());

        if (result.IsSuccess)
        {
            _users = result.Value;
        }
        else
        {
            _error = result.Error?.Message;
        }

        _isLoading = false;
    }
}