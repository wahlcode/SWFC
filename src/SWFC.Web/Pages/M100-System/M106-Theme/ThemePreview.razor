@page "/theme-preview"

<h3 class="theme-title">Theme Preview</h3>

<div class="theme-grid">

    <div class="theme-card">
        <div class="theme-title">Offen</div>
        <ThemeStatusBadge Status="Open" />
    </div>

    <div class="theme-card">
        <div class="theme-title">In Arbeit</div>
        <ThemeStatusBadge Status="InProgress" />
    </div>

    <div class="theme-card">
        <div class="theme-title">Erledigt</div>
        <ThemeStatusBadge Status="Done" />
    </div>

</div>