@page "/m100/roles/{Id:guid}"

@using SWFC.Application.M100_System.M102_Organization.Queries
@using SWFC.Application.M100_System.M102_Organization.DTOs
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution

@inject IExecutionPipeline<GetRoleByIdQuery, RoleDetailsDto> Pipeline

<PageTitle>Role Detail</PageTitle>

<section class="m305-page">
    <div class="m305-page__header">
        <h2 class="m305-page__title">Role Detail</h2>
        <p class="m305-page__description">Detailansicht einer Rolle inklusive technischer Permissions.</p>
    </div>

    <div class="m305-card">
        <div class="m305-card__body">
            @if (_isLoading)
            {
                <p>Lade Daten...</p>
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="m201-alert m201-alert--error">@_error</div>
            }
            else if (_role is not null)
            {
                <dl>
                    <dt>Id</dt>
                    <dd>@_role.Id</dd>

                    <dt>Name</dt>
                    <dd>@_role.Name</dd>

                    <dt>Description</dt>
                    <dd>@DisplayOrDash(_role.Description)</dd>

                    <dt>Permissions</dt>
                    <dd>
                        @if (_role.Permissions.Count == 0)
                        {
                            <span>-</span>
                        }
                        else
                        {
                            @foreach (var permission in _role.Permissions)
                            {
                                <div>@permission</div>
                            }
                        }
                    </dd>
                </dl>

                <div class="m201-form-actions">
                    <a class="m201-button m201-button--secondary" href="/m100/roles">Zur Liste</a>
                </div>
            }
        </div>
    </div>
</section>

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _isLoading = true;
    private string? _error;
    private RoleDetailsDto? _role;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _error = null;

        var result = await Pipeline.ExecuteAsync(new GetRoleByIdQuery(Id));

        if (result.IsSuccess)
        {
            _role = result.Value;
        }
        else
        {
            _error = result.Error?.Message;
        }

        _isLoading = false;
    }

    private static string DisplayOrDash(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }
}