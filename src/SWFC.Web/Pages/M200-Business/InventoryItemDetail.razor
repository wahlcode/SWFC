@page "/m200/inventory-item/{Id:guid}"
@using Microsoft.AspNetCore.Components

<PageTitle>Inventory Item Detail</PageTitle>

<div class="page">
    <h1>Inventory Item Detail</h1>

    <p>
        Inventory item id: <strong>@Id</strong>
    </p>

    <dl>
        <dt>Current Stock</dt>
        <dd>10</dd>

        <dt>Reserved</dt>
        <dd>5</dd>

        <dt>Available</dt>
        <dd>5</dd>
    </dl>

    <p>
        <a href="/m200/stock-reservations">Open stock reservations</a>
    </p>

    <p>
        <a href="/m200/create-stock-reservation">Create stock reservation</a>
    </p>

    <p>
        <a href="/m200/edit-inventory-item/@Id">Edit this inventory item</a>
    </p>

    <p>
        <a href="/m200/inventory-items">Back to list</a>
    </p>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }
}