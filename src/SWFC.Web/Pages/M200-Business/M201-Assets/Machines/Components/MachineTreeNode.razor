@using SWFC.Application.M200_Business.M201_Assets.Machines

<div class="m201-tree-node__row">
    <div class="m201-tree-node__name">
        <div class="m201-tree-node__name-wrap">
            @for (var i = 0; i < Level; i++)
            {
                <span class="m201-tree-node__indent"></span>
            }

            @if (HasChildren)
            {
                <button type="button"
                        class="m201-tree-node__toggle"
                        @onclick="HandleToggleAsync"
                        aria-label="Hierarchie umschalten">
                    @(IsExpanded ? "?" : "?")
                </button>
            }
            else
            {
                <span class="m201-tree-node__bullet">•</span>
            }

            <span class="m201-tree-node__text">@Item.Name</span>
        </div>
    </div>

    <div>@Item.InventoryNumber</div>
    <div>@Item.Status</div>
    <div>@DisplayOrDash(Item.ParentMachineName)</div>

    <div class="m201-tree-node__actions">
        <a href="@($"/machines/{Item.Id}")" class="m201-link">Details</a>
    </div>
</div>

@if (IsExpanded)
{
    @foreach (var child in Children)
    {
        <MachineTreeNode Item="child"
                         Level="@(Level + 1)"
                         ChildrenByParentId="ChildrenByParentId"
                         ExpandedMachineIds="ExpandedMachineIds"
                         OnToggleExpanded="OnToggleExpanded" />
    }
}

@code {
    [Parameter, EditorRequired]
    public MachineListItem Item { get; set; } = default!;

    [Parameter]
    public int Level { get; set; }

    [Parameter, EditorRequired]
    public IReadOnlyDictionary<Guid, List<MachineListItem>> ChildrenByParentId { get; set; } = default!;

    [Parameter, EditorRequired]
    public HashSet<Guid> ExpandedMachineIds { get; set; } = default!;

    [Parameter, EditorRequired]
    public EventCallback<Guid> OnToggleExpanded { get; set; }

    private bool HasChildren => ChildrenByParentId.ContainsKey(Item.Id);

    private bool IsExpanded => ExpandedMachineIds.Contains(Item.Id);

    private IReadOnlyList<MachineListItem> Children =>
        ChildrenByParentId.TryGetValue(Item.Id, out var children)
            ? children
            : Array.Empty<MachineListItem>();

    private Task HandleToggleAsync()
        => OnToggleExpanded.InvokeAsync(Item.Id);

    private static string DisplayOrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;
}


