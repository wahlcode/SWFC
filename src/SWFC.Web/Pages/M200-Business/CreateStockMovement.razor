@page "/m200/create-stock-movement"
@using Microsoft.AspNetCore.Components.Forms
@using SWFC.Application.M200_Business.M204_Inventory.Commands
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution
@using SWFC.Domain.M200_Business.M204_Inventory.Enums

@inject IExecutionPipeline<CreateStockMovementCommand, Guid> Pipeline
@inject NavigationManager NavigationManager

<PageTitle>Create Stock Movement</PageTitle>

<div class="page">
    <h1>Create Stock Movement</h1>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <p class="text-danger">@_errorMessage</p>
    }

    <EditForm Model="Model" OnValidSubmit="HandleValidSubmit" FormName="CreateStockMovementForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="stockId">Stock Id</label>
            <InputText id="stockId" class="form-control" @bind-Value="Model!.StockId" />
        </div>

        <div class="mb-3">
            <label for="movementType">Movement Type</label>
            <InputSelect id="movementType" class="form-control" @bind-Value="Model!.MovementType">
                <option value="@StockMovementType.GoodsReceipt">GoodsReceipt</option>
                <option value="@StockMovementType.GoodsIssue">GoodsIssue</option>
            </InputSelect>
        </div>

        <div class="mb-3">
            <label for="quantityDelta">Quantity Delta</label>
            <InputNumber id="quantityDelta" class="form-control" @bind-Value="Model!.QuantityDelta" />
        </div>

        <div class="mb-3">
            <label for="reason">Reason</label>
            <InputText id="reason" class="form-control" @bind-Value="Model!.Reason" />
        </div>

        <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
            @(_isSubmitting ? "Saving..." : "Save")
        </button>
        <a class="btn btn-link" href="/stock-movements">Cancel</a>
    </EditForm>
</div>

@code {
    [SupplyParameterFromForm(FormName = "CreateStockMovementForm")]
    private CreateStockMovementWebModel? Model { get; set; }

    private string? _errorMessage;
    private bool _isSubmitting;

    protected override void OnInitialized()
    {
        Model ??= new CreateStockMovementWebModel();
    }

    private async Task HandleValidSubmit()
    {
        if (Model is null)
        {
            _errorMessage = "Form data is missing.";
            return;
        }

        _errorMessage = null;
        _isSubmitting = true;

        if (!Guid.TryParse(Model.StockId, out var stockId))
        {
            _errorMessage = "Stock Id is invalid.";
            _isSubmitting = false;
            return;
        }

        var command = new CreateStockMovementCommand(
            stockId,
            Model.MovementType,
            Model.QuantityDelta,
            Model.Reason);

        var result = await Pipeline.ExecuteAsync(command);

        if (result.IsSuccess)
        {
            NavigationManager.NavigateTo("/stock-movements");
            return;
        }

        _errorMessage = result.Error?.Message ?? "Failed to create stock movement.";
        _isSubmitting = false;
    }

    private sealed class CreateStockMovementWebModel
    {
        public string StockId { get; set; } = string.Empty;
        public StockMovementType MovementType { get; set; } = StockMovementType.GoodsReceipt;
        public int QuantityDelta { get; set; }
        public string Reason { get; set; } = string.Empty;
    }
}