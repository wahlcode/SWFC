@page "/m200/stock-reservations"

@using SWFC.Application.M200_Business.M204_Inventory.Queries
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution
@using SWFC.Domain.M200_Business.M204_Inventory.Enums

@inject IExecutionPipeline<GetStockReservationsQuery, IReadOnlyList<StockReservationListItem>> Pipeline

<PageTitle>Stock Reservations</PageTitle>

<div class="page">
    <h1>Stock Reservations</h1>

    @if (HasAssetFilter)
    {
        <p>
            <strong>Filtered for asset:</strong> @TargetReference
        </p>
        <p>
            <a href="@($"/machines/{TargetReference}")">Back to machine</a>
        </p>
    }

    @if (_isLoading)
    {
        <p>Loading...</p>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <p>@_errorMessage</p>
    }
    else if (_reservations.Count == 0)
    {
        <p>No reservations found.</p>
    }
    else
    {
        <div style="overflow-x:auto; width:100%;">
    <table class="table" style="min-width:1400px; width:max-content;">
        <thead>
            <tr>
                <th style="white-space:nowrap;">Id</th>
                <th style="white-space:nowrap;">Stock Id</th>
                <th style="white-space:nowrap;">Quantity</th>
                <th style="white-space:nowrap;">Status</th>
                <th style="white-space:nowrap;">Note</th>
                <th style="white-space:nowrap;">Target Type</th>
                <th style="white-space:nowrap;">Target Reference</th>
                <th style="white-space:nowrap;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var reservation in FilteredReservations)
            {
                <tr>
                    <td style="white-space:nowrap;">@reservation.Id</td>
                    <td style="white-space:nowrap;">@reservation.StockId</td>
                    <td style="white-space:nowrap;">@reservation.Quantity</td>
                    <td style="white-space:nowrap;">@reservation.Status</td>
                    <td style="white-space:nowrap;">@reservation.Note</td>
                    <td style="white-space:nowrap;">@GetTargetTypeDisplay(reservation.TargetType)</td>
                    <td style="white-space:nowrap;">@reservation.TargetReference</td>
                    <td style="white-space:nowrap;">
                        @if (string.Equals(reservation.Status, "Active", StringComparison.OrdinalIgnoreCase) && reservation.Quantity > 0)
                        {
                            <a href="@($"/m200/consume-stock-reservation/{reservation.Id}")">Consume</a>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "targetType")]
    public string? TargetType { get; set; }

    [SupplyParameterFromQuery(Name = "targetReference")]
    public string? TargetReference { get; set; }

    private bool _isLoading = true;
    private string? _errorMessage;
    private IReadOnlyList<StockReservationListItem> _reservations = Array.Empty<StockReservationListItem>();

    private bool HasAssetFilter =>
        string.Equals(TargetType, InventoryTargetType.Asset.ToString(), StringComparison.OrdinalIgnoreCase)
        && !string.IsNullOrWhiteSpace(TargetReference);

    private IEnumerable<StockReservationListItem> FilteredReservations =>
        HasAssetFilter
            ? _reservations.Where(x =>
                x.TargetType.HasValue &&
                x.TargetType.Value == (int)InventoryTargetType.Asset &&
                string.Equals(x.TargetReference, TargetReference, StringComparison.OrdinalIgnoreCase))
            : _reservations;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        var result = await Pipeline.ExecuteAsync(new GetStockReservationsQuery());

        if (result.IsSuccess)
        {
            _reservations = result.Value;
        }
        else
        {
            _errorMessage = result.Error?.Message ?? "Failed to load reservations.";
        }

        _isLoading = false;
    }

    private static string GetTargetTypeDisplay(int? targetType)
    {
        if (!targetType.HasValue)
        {
            return "-";
        }

        return Enum.IsDefined(typeof(InventoryTargetType), targetType.Value)
            ? ((InventoryTargetType)targetType.Value).ToString()
            : targetType.Value.ToString();
    }
}