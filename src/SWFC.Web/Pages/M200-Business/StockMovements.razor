@page "/m200/stock-movements"

@using SWFC.Application.M200_Business.M204_Inventory.Queries
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution

@inject IExecutionPipeline<GetStockMovementsQuery, IReadOnlyList<StockMovementListItem>> Pipeline

<PageTitle>Stock Movements</PageTitle>

<div class="page">
    <h1>Stock Movements</h1>

    <p>
        <a href="/m200/create-stock-movement">Create Stock Movement</a>
    </p>

    @if (_isLoading)
    {
        <p>Loading...</p>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <p class="text-danger">@_errorMessage</p>
    }
    else if (_items.Count == 0)
    {
        <p>No stock movements found.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Movement Type</th>
                    <th>Quantity Delta</th>
                    <th>Stock Id</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _items)
                {
                    <tr>
                        <td>@item.MovementType</td>
                        <td>@item.QuantityDelta</td>
                        <td>@item.StockId</td>
                        <td>
                            <a href="@($"/m200/stock-movement/{item.Id}")">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private IReadOnlyList<StockMovementListItem> _items = Array.Empty<StockMovementListItem>();

    protected override async Task OnInitializedAsync()
    {
        var result = await Pipeline.ExecuteAsync(new GetStockMovementsQuery());

        if (result.IsSuccess)
        {
            _items = result.Value;
        }
        else
        {
            _errorMessage = result.Error?.Message ?? "Failed to load stock movements.";
        }

        _isLoading = false;
    }
}