@page "/machines/create"
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@using SWFC.Application.M200_Business.M201_Assets.Commands
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution
@inject IExecutionPipeline<CreateMachineCommand, Guid> Pipeline
@inject NavigationManager NavigationManager

<PageTitle>Create Machine</PageTitle>

<section class="m305-page">
    <div class="m305-page__header">
        <h2 class="m305-page__title">Create Machine</h2>
        <p class="m305-page__description">Neue Anlage fachlich vollständig anlegen.</p>
    </div>

    <div class="m305-card">
        <div class="m305-card__body">
            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="m201-alert m201-alert--error">@ErrorMessage</div>
            }

            <EditForm Model="Model" OnValidSubmit="HandleValidSubmitAsync" FormName="CreateMachineForm">
                <DataAnnotationsValidator />
                <ValidationSummary class="m201-validation-summary" />

                <div class="m201-form-field">
                    <label class="m201-form-label" for="name">Name</label>
                    <InputText id="name" class="m201-form-input" @bind-Value="Model.Name" />
                    <ValidationMessage For="@(() => Model.Name)" class="m201-validation-message" />
                </div>

                <div class="m201-form-field">
                    <label class="m201-form-label" for="inventory-number">Inventory Number</label>
                    <InputText id="inventory-number" class="m201-form-input" @bind-Value="Model.InventoryNumber" />
                    <ValidationMessage For="@(() => Model.InventoryNumber)" class="m201-validation-message" />
                </div>

                <div class="m201-form-field">
                    <label class="m201-form-label" for="status">Status</label>
                    <InputSelect id="status" class="m201-form-select" @bind-Value="Model.Status">
                        @foreach (var status in StatusOptions)
                        {
                            <option value="@status">@status</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => Model.Status)" class="m201-validation-message" />
                </div>

                <div class="m201-form-field">
                    <label class="m201-form-label" for="location">Location</label>
                    <InputText id="location" class="m201-form-input" @bind-Value="Model.Location" />
                    <ValidationMessage For="@(() => Model.Location)" class="m201-validation-message" />
                </div>

                <div class="m201-form-field">
                    <label class="m201-form-label" for="manufacturer">Manufacturer</label>
                    <InputText id="manufacturer" class="m201-form-input" @bind-Value="Model.Manufacturer" />
                    <ValidationMessage For="@(() => Model.Manufacturer)" class="m201-validation-message" />
                </div>

                <div class="m201-form-field">
                    <label class="m201-form-label" for="model">Model</label>
                    <InputText id="model" class="m201-form-input" @bind-Value="Model.MachineModel" />
                    <ValidationMessage For="@(() => Model.MachineModel)" class="m201-validation-message" />
                </div>

                <div class="m201-form-field">
                    <label class="m201-form-label" for="serial-number">Serial Number</label>
                    <InputText id="serial-number" class="m201-form-input" @bind-Value="Model.SerialNumber" />
                    <ValidationMessage For="@(() => Model.SerialNumber)" class="m201-validation-message" />
                </div>

                <div class="m201-form-field">
                    <label class="m201-form-label" for="description">Description</label>
                    <InputTextArea id="description" class="m201-form-textarea" @bind-Value="Model.Description" />
                    <ValidationMessage For="@(() => Model.Description)" class="m201-validation-message" />
                </div>

                <div class="m201-form-field">
                    <label class="m201-form-label" for="reason">Reason</label>
                    <InputTextArea id="reason" class="m201-form-textarea" @bind-Value="Model.Reason" />
                    <ValidationMessage For="@(() => Model.Reason)" class="m201-validation-message" />
                </div>

                <div class="m201-form-actions">
                    <button type="submit" class="m201-button" disabled="@IsSubmitting">
                        @(IsSubmitting ? "Speichert..." : "Machine anlegen")
                    </button>
                    <a class="m201-button m201-button--secondary" href="/machines">Zur Liste</a>
                </div>
            </EditForm>
        </div>
    </div>
</section>

@code {
    private static readonly string[] StatusOptions =
    [
        "Planned",
        "Active",
        "InMaintenance",
        "Inactive",
        "Retired"
    ];

    [SupplyParameterFromForm(FormName = "CreateMachineForm")]
    private CreateMachineInput Model { get; set; } = new();

    private string? ErrorMessage;
    private bool IsSubmitting;

    private async Task HandleValidSubmitAsync()
    {
        ErrorMessage = null;
        IsSubmitting = true;

        var command = new CreateMachineCommand(
            Model.Name,
            Model.InventoryNumber,
            Model.Location,
            Model.Status,
            Model.Manufacturer,
            Model.MachineModel,
            Model.SerialNumber,
            Model.Description,
            Model.Reason);

        var result = await Pipeline.ExecuteAsync(command);

        if (result.IsSuccess)
        {
            NavigationManager.NavigateTo($"/machines/{result.Value}");
            return;
        }

        ErrorMessage = result.Error.Message;
        IsSubmitting = false;
    }

    private sealed class CreateMachineInput
    {
        [Required(ErrorMessage = "Name ist erforderlich.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Inventory Number ist erforderlich.")]
        public string InventoryNumber { get; set; } = string.Empty;

        [Required(ErrorMessage = "Status ist erforderlich.")]
        public string Status { get; set; } = "Planned";

        public string? Location { get; set; }
        public string? Manufacturer { get; set; }
        public string? MachineModel { get; set; }
        public string? SerialNumber { get; set; }
        public string? Description { get; set; }

        [Required(ErrorMessage = "Grund ist erforderlich.")]
        public string Reason { get; set; } = string.Empty;
    }
}