@page "/machines/create"
@using SWFC.Application.M200_Business.M201_Assets.Commands
@using SWFC.Application.M200_Business.M201_Assets.Handlers
@inject CreateMachineHandler Handler

<h3>Create Machine</h3>

<div class="mb-3">
    <label class="form-label">Name</label>
    <input class="form-control" value="@Name" @oninput="OnNameChanged" />
</div>

<div class="mb-3">
    <label class="form-label">Reason</label>
    <input class="form-control" value="@Reason" @oninput="OnReasonChanged" />
</div>

<button class="btn btn-primary" @onclick="CreateAsync">Create</button>

@if (!string.IsNullOrWhiteSpace(Message))
{
    <div class="mt-3 alert alert-info">@Message</div>
}

@code {
    private string Name { get; set; } = string.Empty;
    private string Reason { get; set; } = string.Empty;
    private string? Message;

    private void OnNameChanged(ChangeEventArgs e)
    {
        Name = e.Value?.ToString() ?? string.Empty;
    }

    private void OnReasonChanged(ChangeEventArgs e)
    {
        Reason = e.Value?.ToString() ?? string.Empty;
    }

    private async Task CreateAsync()
    {
        try
        {
            var command = new CreateMachineCommand(Name, Reason);
            var result = await Handler.HandleAsync(command);

            Message = result.IsSuccess
                ? $"Machine created successfully. Id: {result.Value}"
                : result.Error?.Message ?? "Creation failed.";

            if (result.IsSuccess)
            {
                Name = string.Empty;
                Reason = string.Empty;
            }
        }
        catch (Exception ex)
        {
            Message = ex.Message;
        }
    }
}