@page "/business/inventory"

<PageTitle>M204 Inventar</PageTitle>

<section class="module-landing-page">
    <div class="module-landing-page__header">
        <div class="module-landing-page__eyebrow">M204</div>
        <h1 class="module-landing-page__title">Inventar</h1>
        <p class="module-landing-page__description">
            Einstieg in Bestände, Bewegungen und Reservierungen.
        </p>
    </div>

    <div class="module-landing-page__grid">
        <a class="module-landing-card" href="/inventory-items">
            <div class="module-landing-card__code">M204</div>
            <div class="module-landing-card__title">Inventarpositionen</div>
            <div class="module-landing-card__text">
                Überblick über Bestand, reservierte Menge und verfügbare Menge.
            </div>
        </a>

        <a class="module-landing-card" href="/m200/stock-movements">
            <div class="module-landing-card__code">M204</div>
            <div class="module-landing-card__title">Bestandsbewegungen</div>
            <div class="module-landing-card__text">
                Übersicht über Zu- und Abgänge im Inventar.
            </div>
        </a>

        <a class="module-landing-card" href="/m200/stock-reservations">
            <div class="module-landing-card__code">M204</div>
            <div class="module-landing-card__title">Reservierungen</div>
            <div class="module-landing-card__text">
                Übersicht über aktive und historische Reservierungen.
            </div>
        </a>
    </div>
</section>