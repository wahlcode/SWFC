@page "/create-stock-reservation"
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@using SWFC.Application.M200_Business.M204_Inventory.Commands
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution
@using SWFC.Domain.M200_Business.M204_Inventory.Enums
@inject IExecutionPipeline<CreateStockReservationCommand, Guid> Pipeline
@inject NavigationManager NavigationManager

<PageTitle>Create Stock Reservation</PageTitle>

<div class="page">
    <h1>Create Stock Reservation</h1>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <p class="text-danger">@_errorMessage</p>
    }

    @if (HasMachineContext)
    {
        <div class="mb-3">
            <strong>Machine Context:</strong> @Model?.TargetReference
        </div>
    }

    <EditForm Model="Model" OnValidSubmit="HandleValidSubmit" FormName="CreateStockReservationForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="stockId">Stock Id</label>
            <InputText id="stockId" class="form-control" @bind-Value="Model!.StockId" />
            <ValidationMessage For="@(() => Model!.StockId)" />
        </div>

        <div class="mb-3">
            <label for="quantity">Quantity</label>
            <InputNumber id="quantity" class="form-control" @bind-Value="Model!.Quantity" />
            <ValidationMessage For="@(() => Model!.Quantity)" />
        </div>

        <div class="mb-3">
            <label for="note">Note</label>
            <InputText id="note" class="form-control" @bind-Value="Model!.Note" />
        </div>

        <div class="mb-3">
            <label for="reason">Reason</label>
            <InputText id="reason" class="form-control" @bind-Value="Model!.Reason" />
            <ValidationMessage For="@(() => Model!.Reason)" />
        </div>

        @if (HasMachineContext)
        {
            <div class="mb-3">
                <label class="form-label">Target Type</label>
                <input class="form-control" value="Asset" disabled />
            </div>

            <div class="mb-3">
                <label class="form-label">Target Reference</label>
                <input class="form-control" value="@Model?.TargetReference" disabled />
            </div>
        }
        else
        {
            <div class="mb-3">
                <label class="form-label">Target Type</label>
                <InputSelect TValue="InventoryTargetType?" @bind-Value="Model!.TargetType" class="form-control">
                    <option value="">-- none --</option>
                    @foreach (var value in Enum.GetValues<InventoryTargetType>())
                    {
                        <option value="@value">@value</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Target Reference</label>
                <InputText @bind-Value="Model!.TargetReference" class="form-control" />
            </div>
        }

        <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">Save</button>
        <a class="btn btn-link" href="@GetCancelUrl()">Cancel</a>
    </EditForm>
</div>

@code {
    [SupplyParameterFromQuery(Name = "machineId")]
    public Guid? MachineId { get; set; }

    [SupplyParameterFromForm(FormName = "CreateStockReservationForm")]
    private CreateStockReservationWebModel? Model { get; set; }

    private bool _isSubmitting;
    private string? _errorMessage;

    private bool HasMachineContext => MachineId.HasValue && MachineId.Value != Guid.Empty;

    protected override void OnParametersSet()
    {
        Model ??= new CreateStockReservationWebModel();

        if (HasMachineContext)
        {
            Model.TargetType = InventoryTargetType.Asset;
            Model.TargetReference = MachineId!.Value.ToString();
        }
    }

    private async Task HandleValidSubmit()
    {
        if (Model is null)
        {
            _errorMessage = "Form data is missing.";
            return;
        }

        _errorMessage = null;
        _isSubmitting = true;

        if (!Guid.TryParse(Model.StockId, out var stockId))
        {
            _errorMessage = "Stock Id is invalid.";
            _isSubmitting = false;
            return;
        }

        var command = new CreateStockReservationCommand(
            stockId,
            Model.Quantity,
            Model.Note,
            Model.Reason,
            Model.TargetType,
            Model.TargetReference);

        var result = await Pipeline.ExecuteAsync(command);

        if (result.IsSuccess)
        {
            NavigationManager.NavigateTo(GetSuccessUrl());
            return;
        }

        _errorMessage = result.Error?.Message ?? "Failed to create stock reservation.";
        _isSubmitting = false;
    }

    private string GetSuccessUrl()
    {
        if (HasMachineContext)
        {
            return $"/machines/{MachineId}";
        }

        return "/stock-reservations";
    }

    private string GetCancelUrl()
    {
        if (HasMachineContext)
        {
            return $"/machines/{MachineId}";
        }

        return "/stock-reservations";
    }

    private sealed class CreateStockReservationWebModel
    {
        [Required(ErrorMessage = "Stock Id is required.")]
        public string StockId { get; set; } = string.Empty;

        [Range(1, int.MaxValue, ErrorMessage = "Quantity must be greater than 0.")]
        public int Quantity { get; set; }

        public string Note { get; set; } = string.Empty;

        [Required(ErrorMessage = "Reason is required.")]
        public string Reason { get; set; } = string.Empty;

        public InventoryTargetType? TargetType { get; set; }
        public string? TargetReference { get; set; }
    }
}