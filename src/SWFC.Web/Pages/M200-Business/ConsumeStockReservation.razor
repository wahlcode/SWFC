@page "/m200/consume-stock-reservation/{Id:guid}"

@using Microsoft.AspNetCore.Components.Forms
@using SWFC.Application.M200_Business.M204_Inventory.Commands
@using SWFC.Application.M200_Business.M204_Inventory.Queries
@using SWFC.Application.M800_Security.M802_ApplicationSecurity.Pipeline.Execution
@using SWFC.Domain.M200_Business.M204_Inventory.Enums

@inject IExecutionPipeline<GetStockReservationByIdQuery, StockReservationDetailsDto> GetPipeline
@inject IExecutionPipeline<ConsumeStockReservationCommand, Guid> ConsumePipeline
@inject NavigationManager NavigationManager

<PageTitle>Consume Stock Reservation</PageTitle>

<div class="page">
    <h1>Consume Stock Reservation</h1>

    @if (_isLoading)
    {
        <p>Loading...</p>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <p class="text-danger">@_errorMessage</p>
    }
    else if (_reservation is null)
    {
        <p>Reservation not found.</p>
    }
    else
    {
        <div class="mb-3">
            <strong>Reservation Id:</strong> @_reservation.Id
        </div>

        <div class="mb-3">
            <strong>Stock Id:</strong> @_reservation.StockId
        </div>

        <div class="mb-3">
            <strong>Reserved Quantity:</strong> @_reservation.Quantity
        </div>

        <div class="mb-3">
            <strong>Status:</strong> @_reservation.Status
        </div>

        <div class="mb-3">
            <strong>Target Type:</strong> @GetTargetTypeDisplay(_reservation.TargetType)
        </div>

        <div class="mb-3">
            <strong>Target Reference:</strong> @(string.IsNullOrWhiteSpace(_reservation.TargetReference) ? "-" : _reservation.TargetReference)
        </div>

        <EditForm Model="Model" OnValidSubmit="HandleValidSubmit" FormName="ConsumeStockReservationForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Quantity to consume</label>
                <InputNumber @bind-Value="Model!.Quantity" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Reason</label>
                <InputText @bind-Value="Model!.Reason" class="form-control" />
            </div>

            <button type="submit" class="btn btn-danger" disabled="@_isSubmitting">
                @(_isSubmitting ? "Processing..." : "Consume")
            </button>
        </EditForm>
    }

    <p>
        <a href="@GetBackUrl()">Back</a>
    </p>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    [SupplyParameterFromForm(FormName = "ConsumeStockReservationForm")]
    private FormModel? Model { get; set; }

    private bool _isLoading = true;
    private bool _isSubmitting;
    private string? _errorMessage;
    private StockReservationDetailsDto? _reservation;

    protected override async Task OnParametersSetAsync()
    {
        Model ??= new FormModel();

        _isLoading = true;
        _errorMessage = null;

        var result = await GetPipeline.ExecuteAsync(new GetStockReservationByIdQuery(Id));

        if (result.IsSuccess)
        {
            _reservation = result.Value;
        }
        else
        {
            _errorMessage = result.Error?.Message ?? "Failed to load reservation.";
        }

        _isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        if (Model is null)
        {
            _errorMessage = "Form data is missing.";
            return;
        }

        _isSubmitting = true;
        _errorMessage = null;

        var command = new ConsumeStockReservationCommand(
            Id,
            Model.Quantity,
            Model.Reason);

        var result = await ConsumePipeline.ExecuteAsync(command);

        if (result.IsSuccess)
        {
            NavigationManager.NavigateTo($"/m200/stock-movement/{result.Value}");
            return;
        }

        _errorMessage = result.Error?.Message ?? "Consumption failed.";
        _isSubmitting = false;
    }

    private string GetBackUrl()
    {
        if (_reservation?.TargetType.HasValue == true &&
            _reservation.TargetType.Value == (int)InventoryTargetType.Asset &&
            Guid.TryParse(_reservation.TargetReference, out var machineId))
        {
            return $"/machines/{machineId}";
        }

        return "/stock-reservations";
    }

    private static string GetTargetTypeDisplay(int? targetType)
    {
        if (!targetType.HasValue)
        {
            return "-";
        }

        return Enum.IsDefined(typeof(InventoryTargetType), targetType.Value)
            ? ((InventoryTargetType)targetType.Value).ToString()
            : targetType.Value.ToString();
    }

    private sealed class FormModel
    {
        public int Quantity { get; set; }
        public string Reason { get; set; } = string.Empty;
    }
}